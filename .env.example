# Movorb data source. Set ONE provider; the app picks the first that's configured,
# falling back to keyless imdbapi.dev and then a built-in set. Copy to `.env`.

# TheTVDB (primary) — get a key at https://www.thetvdb.com/dashboard/account/apikey
# Project/company keys need no PIN. User-supported keys also set THETVDB_PIN.
THETVDB_KEY=
THETVDB_PIN=

# TMDB (alternative) — https://www.themoviedb.org/settings/api
# A v4 "API Read Access Token" (long JWT) or a v3 "API Key" both work.
TMDB_KEY=https://www.thetvdb.com/api-information
